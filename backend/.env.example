# Database
DATABASE_URL="postgresql://username:password@localhost:5432/forum_excellence"

# JWT (minimum 32 characters; secrets must be different)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_SECRET_PREVIOUS=
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_SECRET_PREVIOUS=
JWT_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# Shared secret manager (optional)
# SECRET_MANAGER=aws
# AWS_REGION=us-east-1
# AWS_SECRET_ID=your-secret-id
# JWT_SECRET_POLL_INTERVAL_MS=300000

# Security alerts
# Alerts are emitted as structured logs (CloudWatch-friendly)
# ALERT_PROVIDER=cloudwatch

# Rotation procedure:
# 1) Set JWT_SECRET_PREVIOUS to the current JWT_SECRET
# 2) Set JWT_SECRET to a new value
# 3) Set JWT_REFRESH_SECRET_PREVIOUS to the current JWT_REFRESH_SECRET
# 4) Set JWT_REFRESH_SECRET to a new value
# 5) Deploy all instances with the updated secrets

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Public origin used to build absolute URLs for uploaded assets.
# REQUIRED in production behind a reverse proxy (Render, Cloudflare, etc.)
# because the Host header is attacker-controlled.
# Example: BACKEND_PUBLIC_URL=https://api.forumexcellence.sn
BACKEND_PUBLIC_URL=http://localhost:5000

# Reverse-proxy hop count (Render = 1, Cloudflare→Render = 2, etc.).
# Defaults to 1 in production, off otherwise. Set to a number, 'true', 'false',
# or a comma-separated list of trusted IPs/CIDRs (cf. express docs).
# TRUST_PROXY=1

# Redis (required in production for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Email (used for password-reset emails — see backend/src/services/mailService.ts)
# Admin-edited values in EmailSettings (Prisma) take precedence over these.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@forumexcellence.sn
SMTP_FROM_NAME=Forum de L'excellence